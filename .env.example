# Philips Hue Bridge Configuration
# =================================
# Required for light control. Audio-only mode works without these.

BRIDGE_IP=192.168.1.100
HUE_USERNAME=your-username-here
HUE_CLIENTKEY=your-clientkey-here
ENTERTAINMENT_AREA_ID=1


# Optional Configuration
# ======================
# All settings below have sensible defaults. Uncomment to customize.

# Audio
# AUDIO_DEVICE_INDEX=        # PyAudio device index (blank = system default)
# SAMPLE_RATE=44100
# BUFFER_SIZE=1024
# FFT_SIZE=2048

# Performance
# FPS_TARGET=50              # Light update rate (Hz)

# Beat Detection
# BEAT_COOLDOWN_MS=300       # Min inter-beat interval (ms)
# BPM_MIN=80                 # BPM range for octave error protection
# BPM_MAX=180

# Smoothing
# ATTACK_ALPHA=0.7           # EMA fast attack (0.5–0.8)
# RELEASE_ALPHA=0.1          # EMA slow release (0.05–0.15)
# BRIGHTNESS_GAMMA=2.2       # Perceptual gamma correction
# BASS_BOOST_FACTOR=2.0      # Fletcher-Munson compensation

# Predictive Beat Triggering
# LATENCY_COMPENSATION_MS=80
# PREDICTIVE_CONFIDENCE_THRESHOLD=0.6

# Brightness Limits
# BRIGHTNESS_MIN=0.0
# BRIGHTNESS_MAX=1.0

# Safety
# MAX_FLASH_HZ=3.0           # Epilepsy safety limit

# Server
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080
