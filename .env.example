# Philips Hue Bridge Configuration (REQUIRED)
# ============================================

# IP address of your Hue Bridge (find it in the Hue app or use discovery script)
BRIDGE_IP=192.168.1.100

# Username/API token (obtain via scripts/setup_bridge.py)
HUE_USERNAME=your-username-here

# Entertainment Area ID (create via Hue app, usually "1" for first area)
ENTERTAINMENT_AREA_ID=1


# Optional Configuration
# ======================
# All settings below have sensible defaults and can be omitted.
# Uncomment and modify only if you need to customize.

# AUDIO_SOURCE=microphone
# BUFFER_SIZE=1024
# SAMPLE_RATE=44100
# FPS_TARGET=50
# BEAT_THRESHOLD_MULTIPLIER=1.5
# BEAT_COOLDOWN_MS=200
# DECAY_FACTOR=0.90

# Predictive Beat Triggering
# Fires light commands early to compensate for system latency (audio → bridge → bulb).
# Set to 0 to disable. Requires PLL confidence above the threshold to activate.
# LATENCY_COMPENSATION_MS=80
# PREDICTIVE_CONFIDENCE_THRESHOLD=0.6
